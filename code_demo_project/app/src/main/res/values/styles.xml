<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.CalcDemo.Key" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">20sp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.CalcDemo.Key.Digit" parent="Widget.CalcDemo.Key">
        <item name="backgroundTint">@color/calc_key_digit</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.CalcDemo.Key.Op" parent="Widget.CalcDemo.Key">
        <item name="backgroundTint">@color/calc_key_op</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.CalcDemo.Key.Func" parent="Widget.CalcDemo.Key">
        <item name="backgroundTint">@color/calc_key_func</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
